DATABASE_URL=postgresql://admin:admin@postgres:5432/proxy_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=super-secret-key

EMAIL_BACKEND=console
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=mailtrap_username
SMTP_PASSWORD=mailtrap_password
SMTP_FROM_EMAIL=no-reply@proxy-service.local
SMTP_USE_TLS=true

PUBLIC_WS_BASE_URL=ws://localhost:8000
AUTO_SEED_VMS=true
